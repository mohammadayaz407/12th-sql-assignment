-- Find customer names and their products
select name,product from customers inner join orders on 
customers.customer_id=orders.customer_id;


-- Find total amount spent by each customer
select name,price from customers inner join orders on 
customers.customer_id=orders.customer_id;

-- Find customers who ordered more than 1 product
select customers.customer_id,name,count(customers.customer_id) as total_orders from customers inner join orders on 
customers.customer_id=orders.customer_id  group by customers.customer_id,name  having total_orders>1;



-- Get customer names and product names for all orders
select name,product from customers left join orders on
customers.customer_id=orders.customer_id;


-- Find customers who placed orders with amount greater than 2000
select name,price from customers right join orders on 
customers.customer_id=orders.customer_id having price>2000;

-- Get customer name, city, and product name where city is 'Hyderabad'
select name,product,city from customers left join orders on
customers.customer_id=orders.customer_id where city='hyderabad';

-- Find all orders where product name starts with 'S' and amount is greater than 10000
select product,price from customers right join orders on 
customers.customer_id=orders.customer_id  where product like'm%' and price>10000;

-- Get customers who ordered products between amount 10000 and 50000
select product,price from customers right join orders on 
customers.customer_id=orders.customer_id where price between 10000 and 50000;

-- Find customer names who ordered either 'Laptop' or 'Mobile'
select name,product from customers inner join orders on 
customers.customer_id=orders.customer_id where product in('laptop','mobile');

-- Get top 5 highest order amounts with customer names
select name,price from customers inner join orders on 
customers.customer_id=orders.customer_id order by price desc limit 5; 

-- Skip first 5 highest orders and get next 5 records with customer name and amount
select name,price from customers inner join orders on 
customers.customer_id=orders.customer_id order by price desc limit 5 offset 5;

-- Find customers whose name starts with 'A' and who placed orders greater than 30000
select name,price from customers inner join orders on
customers.customer_id=orders.customer_id where name like 'a%' and price>30000;

-- 10. 🔥 (Advanced)
-- Get customer name, city, product name where:
-- city is 'Delhi' OR 'Mumbai'
-- amount > 20000
-- product name contains 'Pro'
-- show only 3 records after skipping first 2 records
select name,city,product from customers inner join orders on
customers.customer_id=orders.customer_id where customers.city in('delhi','mumbai') and orders.product  like '%pro%' and orders.price>20000 limit 3 offset 2 ;

